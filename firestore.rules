rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: employees
    // Fields: id, name, role, department, branch, baseSalary, travelingAllowance, vehicleAllowance, performanceAllowance, petrolLitres, attendanceBonus, overtime, bikeInstallment, staffLoan, bankName, bankBranch, accountNo, hasEPF
    //
    // Collection: attendance
    // Fields: id, empId, date, status, checkIn, checkOut
    //
    // Collection: leaves
    // Fields: id, empId, type, from, to, status, reason
    //
    // Collection: advances
    // Fields: id, empId, amount, date, status, reason, isPaid
    //
    // Collection: targets
    // Fields: id, empId, month, category, targetCount, achievedCount
    //
    // Collection: auditLogs
    // Fields: id, timestamp, user, action, details, type
    //
    // Collection: settings
    // Fields: companyName, companySubtitle, fuelPrice, leavePolicy, workSchedule, theme
    //
    // Collection: paidDeductions
    // Fields: months
    //
    // Collection: credentials
    // Fields: empId, username, password, isAdmin
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      return isAuthenticated() && 
        request.auth.token != null &&
        request.auth.token.email != null && 
        request.auth.token.email == "zioncommercialcreditampara@gmail.com";
    }

    function isAdmin() {
      return isMasterAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isOwner(empId) {
      return isAuthenticated() && (
        isMasterAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.empId == empId) ||
        (request.auth.token.email != null && resource != null && 'email' in resource.data && resource.data.email == request.auth.token.email && request.auth.token.email_verified == true)
      );
    }

    function isValidAttendance(data) {
      return data.empId is string && data.date is string && data.status in ['Present', 'Absent', 'Late', 'Leave', 'Half Day'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /employees/{empId} {
      allow read: if isAuthenticated() && (isOwner(empId) || isAdmin());
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (isOwner(empId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['profilePic']))
      );
      allow create, delete: if isAdmin();
    }

    match /attendance/{id} {
      allow read: if isAuthenticated() && (isOwner(resource.data.empId) || isAdmin());
      allow create: if isAuthenticated() && (isOwner(request.resource.data.empId) || isAdmin()) && isValidAttendance(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /leaves/{id} {
      allow read: if isAuthenticated() && (isOwner(resource.data.empId) || isAdmin());
      allow create: if isAuthenticated() && (isOwner(request.resource.data.empId) || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /advances/{id} {
      allow read: if isAuthenticated() && (isOwner(resource.data.empId) || isAdmin());
      allow create: if isAuthenticated() && (isOwner(request.resource.data.empId) || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /cashRequests/{id} {
      allow read: if isAuthenticated() && (isOwner(resource.data.empId) || isAdmin());
      allow create: if isAuthenticated() && (isOwner(request.resource.data.empId) || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /targets/{id} {
      allow read: if isAuthenticated() && (isOwner(resource.data.empId) || isAdmin());
      allow write: if isAdmin();
    }

    match /auditLogs/{id} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /payrollReceipts/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /paidDeductions/{empId} {
      allow read: if isAuthenticated() && (isOwner(empId) || isAdmin());
      allow write: if isAdmin();
    }

    match /leaveBalances/{empId} {
      allow read: if isAuthenticated() && (isOwner(empId) || isAdmin());
      allow write: if isAdmin();
    }

    match /credentials/{username} {
      // Credentials must NEVER be publicly listable.
      // We allow 'get' for authentication purposes so the client can verify passwords.
      allow get: if isAuthenticated();
      allow list, write: if isAdmin();
    }

    match /test/{id} {
      allow read: if true;
    }
    
    match /directory/{empId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isMasterAdmin());
      allow write: if isAuthenticated() && request.auth.uid == uid && (
        isMasterAdmin() ||
        ( 
          'username' in request.resource.data &&
          'passToken' in request.resource.data &&
          exists(/databases/$(database)/documents/credentials/$(request.resource.data.username)) &&
          get(/databases/$(database)/documents/credentials/$(request.resource.data.username)).data.password == request.resource.data.passToken &&
          get(/databases/$(database)/documents/credentials/$(request.resource.data.username)).data.empId == request.resource.data.empId &&
          (request.resource.data.role == 'admin' ? get(/databases/$(database)/documents/credentials/$(request.resource.data.username)).data.isAdmin == true : true)
        ) ||
        (
          'email' in request.resource.data && 
          request.auth.token.email != null &&
          request.resource.data.email == request.auth.token.email
        )
      );
    }

    match /adhocBonuses/{id} {
      allow read: if isAuthenticated() && (isAdmin() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.empId == resource.data.empId));
      allow write: if isAdmin();
    }

    match /messages/{id} {
      allow read: if isAuthenticated() && (
        isMasterAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.empId in resource.data.participants) ||
        resource.data.senderId == request.auth.uid
      );
      allow create: if isAuthenticated() && (
        request.resource.data.senderId == (exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.empId : request.auth.uid)
      );
      allow update: if isAuthenticated() && (
        resource.data.senderId == (exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.empId : request.auth.uid)
      );
      allow delete: if isAdmin();
    }
  }
}
